# ============================================================
# STEINZ LABS — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================


# ── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production: https://app.steinzlabs.com


# ── Database (Supabase PostgreSQL) ───────────────────────────
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...


# ── ThirdWeb (Wallet Connections) ────────────────────────────
# Get from: https://thirdweb.com/dashboard/settings
NEXT_PUBLIC_THIRDWEB_CLIENT_ID=your_thirdweb_client_id
THIRDWEB_SECRET_KEY=your_thirdweb_secret_key


# ── Alchemy (EVM RPC + Portfolio) ────────────────────────────
# Get from: https://dashboard.alchemy.com
NEXT_PUBLIC_ALCHEMY_API_KEY=your_alchemy_api_key
# Per-chain RPC (optional — defaults to Alchemy public)
ALCHEMY_RPC_ETHEREUM=https://eth-mainnet.g.alchemy.com/v2/your_key
ALCHEMY_RPC_BASE=https://base-mainnet.g.alchemy.com/v2/your_key
ALCHEMY_RPC_ARBITRUM=https://arb-mainnet.g.alchemy.com/v2/your_key
ALCHEMY_RPC_POLYGON=https://polygon-mainnet.g.alchemy.com/v2/your_key


# ── Helius (Solana RPC + Portfolio) ──────────────────────────
# Get from: https://helius.dev
NEXT_PUBLIC_HELIUS_API_KEY=your_helius_api_key
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your_key


# ── CoinGecko (Market Data) ───────────────────────────────────
# Get from: https://coingecko.com/en/api
# Free tier works — Pro gives higher rate limits
NEXT_PUBLIC_COINGECKO_API_KEY=CG-your_coingecko_key


# ── LunarCrush (Social Intelligence) ─────────────────────────
# Get from: https://lunarcrush.com/developers
# 3 keys for round-robin fallback
LUNARCRUSH_API_KEY_1=your_lunarcrush_key_1
LUNARCRUSH_API_KEY_2=your_lunarcrush_key_2
LUNARCRUSH_API_KEY_3=your_lunarcrush_key_3


# ── Anthropic (VTX AI — Claude) ──────────────────────────────
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key


# ── 0x Protocol (EVM Swaps) ───────────────────────────────────
# Get from: https://0x.org/docs/introduction/getting-started
# Required for live EVM trade execution (ETH/BSC/Base/Arbitrum/Polygon)
ZEROX_API_KEY=your_0x_api_key


# ── GoPlus Security (Token Scanning) ─────────────────────────
# Get from: https://gopluslabs.io
GOPLUS_API_KEY=your_goplus_api_key


# ── Resend (Email Notifications) ─────────────────────────────
# Get from: https://resend.com
RESEND_API_KEY=re_your_resend_api_key
FROM_EMAIL=alerts@steinzlabs.com


# ── Treasury Wallets (Fee Collection) ────────────────────────
# These wallets receive the 0.1% trading fee
NEXT_PUBLIC_TREASURY_WALLET_EVM=0xYourEVMTreasuryWalletAddress
NEXT_PUBLIC_TREASURY_WALLET_SOLANA=YourSolanaTreasuryWalletAddress


# ── Privy (Legacy Auth — Optional) ────────────────────────────
# Only needed if using Privy alongside ThirdWeb
NEXT_PUBLIC_PRIVY_APP_ID=your_privy_app_id
PRIVY_APP_SECRET=your_privy_app_secret


# ── Optional: Upstash Redis (Rate Limiting / Caching) ─────────
# Enables real-time price caching + API rate limiting
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token


# ── Optional: Sentry (Error Tracking) ────────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://your@sentry.io/project
SENTRY_AUTH_TOKEN=your_sentry_token
